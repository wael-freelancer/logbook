---
import { formatDate } from '@/lib/utils';
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
  featured?: boolean;
}

const { project, featured = false } = Astro.props;

const statusLabels = {
  active: 'Active',
  archived: 'Archived',
  wip: 'In Progress',
};
---

<article class={`group rounded-lg border border-border bg-surface transition-all hover:shadow-md ${featured ? 'sm:col-span-2' : ''}`}>
  <a href={`/projects/${project.id}`} class="block p-6">
    <!-- Status badge -->
    {project.data.status && (
      <div class="flex items-center gap-2">
        <span class="inline-flex items-center rounded-full bg-primary/10 px-2 py-0.5 text-xs font-medium text-primary capitalize">
          {statusLabels[project.data.status] ?? project.data.status}
        </span>
      </div>
    )}

    <h3 class={`mt-3 font-display font-semibold tracking-tight text-text group-hover:text-primary transition-colors ${featured ? 'text-xl' : 'text-lg'}`}>
      {project.data.title}
    </h3>

    <p class="mt-2 text-sm text-text-secondary leading-relaxed line-clamp-2">
      {project.data.description}
    </p>

    <!-- Links -->
    {(project.data.liveUrl || project.data.repoUrl) && (
      <div class="mt-3 flex items-center gap-3 text-xs text-text-tertiary">
        {project.data.liveUrl && (
          <span class="flex items-center gap-1 group-hover:text-primary transition-colors">
            Live Demo
          </span>
        )}
        {project.data.repoUrl && (
          <span class="flex items-center gap-1 group-hover:text-primary transition-colors">
            Source Code
          </span>
        )}
      </div>
    )}

    <!-- Tags -->
    {project.data.tags.length > 0 && (
      <div class="mt-4 flex flex-wrap gap-1.5">
        {project.data.tags.slice(0, 3).map((tag: string) => (
          <span class="inline-flex items-center rounded-full bg-surface-2 px-2 py-0.5 text-xs font-medium text-text-secondary group-hover:text-primary transition-colors">
            {tag}
          </span>
        ))}
      </div>
    )}
  </a>
</article>
