---
import { getFeaturedProjects } from '@/lib/projects';
import ProjectCard from '@/components/projects/ProjectCard.astro';

const projects = await getFeaturedProjects(3);
---

<section class="featured-work mx-auto w-full max-w-screen-xl px-4 sm:px-6 lg:px-8 py-20">
  <h2 class="mb-10 font-display text-3xl font-semibold tracking-tight text-text sm:text-4xl">
    Featured Work
  </h2>

  {projects.length > 0 ? (
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {projects.map((project, index) => (
        <ProjectCard project={project} />
      ))}
    </div>
  ) : (
    <p class="text-text-secondary">No featured projects yet.</p>
  )}
</section>

<style is:global>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .featured-work h2 {
    animation: fadeInUp 0.6s ease-out forwards;
  }

  .featured-work .grid > * {
    opacity: 0;
    animation: fadeInUp 0.5s ease-out forwards;
  }

  .featured-work .grid > *:nth-child(1) { animation-delay: 0.1s; }
  .featured-work .grid > *:nth-child(2) { animation-delay: 0.2s; }
  .featured-work .grid > *:nth-child(3) { animation-delay: 0.3s; }

  @media (prefers-reduced-motion: reduce) {
    .featured-work h2,
    .featured-work .grid > * {
      opacity: 1;
      animation: none;
    }
  }
</style>
