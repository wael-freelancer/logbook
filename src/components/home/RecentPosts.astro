---
import { getSortedPosts } from '@/lib/posts';
import PostCard from '@/components/blog/PostCard.astro';

const posts = await getSortedPosts();
const recent = posts.slice(0, 3);
---

<section class="recent-posts mx-auto w-full max-w-screen-xl px-4 sm:px-6 lg:px-8 py-20">
  <h2 class="mb-10 font-display text-3xl font-semibold tracking-tight text-text sm:text-4xl">
    Latest Posts
  </h2>

  {recent.length > 0 ? (
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {recent.map((post) => (
        <PostCard post={post} />
      ))}
    </div>
  ) : (
    <p class="text-text-secondary">No posts yet.</p>
  )}
</section>

<style is:global>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .recent-posts h2 {
    animation: fadeInUp 0.6s ease-out forwards;
  }

  .recent-posts .grid > * {
    opacity: 0;
    animation: fadeInUp 0.5s ease-out forwards;
  }

  .recent-posts .grid > *:nth-child(1) { animation-delay: 0.1s; }
  .recent-posts .grid > *:nth-child(2) { animation-delay: 0.2s; }
  .recent-posts .grid > *:nth-child(3) { animation-delay: 0.3s; }

  @media (prefers-reduced-motion: reduce) {
    .recent-posts h2,
    .recent-posts .grid > * {
      opacity: 1;
      animation: none;
    }
  }
</style>
