---
import { getSortedPosts } from '@/lib/posts';
import PostCard from '@/components/blog/PostCard.astro';

const posts = await getSortedPosts();
const recent = posts.slice(0, 3);
---

<section class="mx-auto w-full max-w-screen-xl px-4 sm:px-6 lg:px-8 py-20">
  <h2 class="mb-10 font-display text-3xl font-semibold tracking-tight text-text sm:text-4xl opacity-0 animate-fade-in-up motion-reduce:opacity-100 motion-reduce:animate-none">
    Latest Posts
  </h2>

  {recent.length > 0 ? (
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {recent.map((post, index) => (
        <div
          class="opacity-0 animate-fade-in-up [animation-duration:0.5s] motion-reduce:opacity-100 motion-reduce:animate-none"
          style={`animation-delay:${0.1 + index * 0.1}s`}
        >
          <PostCard post={post} />
        </div>
      ))}
    </div>
  ) : (
    <p class="text-text-secondary">No posts yet.</p>
  )}
</section>
