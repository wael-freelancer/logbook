---
interface Props {
  name?: string;
  role?: string;
  tagline?: string;
}

const {
  name = 'Wael',
  role = 'Software Engineer',
  tagline = 'I build things for the web and write about the process.',
} = Astro.props;
---

<section class="relative mx-auto w-full px-4 sm:px-6 lg:px-8">
  <!-- Background decorative elements -->
    <div class="pointer-events-none absolute inset-0 overflow-hidden">
    <div class="absolute -left-[10rem] top-1/4 z-[-1] h-96 w-96 will-change-transform rounded-full bg-gradient-to-br from-primary/20 to-transparent blur-3xl animate-orb-float motion-reduce:animate-none" />
    <div class="absolute -right-[10rem] top-1/3 z-[-1] h-80 w-80 will-change-transform rounded-full bg-gradient-to-bl from-primary/15 via-primary/5 to-transparent blur-3xl animate-orb-float [animation-duration:25s] [animation-delay:-10s] motion-reduce:animate-none" />
  </div>

  <div class="relative mx-auto flex min-h-[70vh] max-w-screen-xl flex-col items-center justify-center py-24 text-center">
    <!-- Decorative line -->
    <div class="mb-8 h-px w-16 bg-gradient-to-b from-primary/60 to-transparent sm:mb-10 opacity-0 animate-fade-in-up [animation-delay:0.1s] motion-reduce:opacity-100 motion-reduce:animate-none" />

    <!-- Name -->
    <h1 class="mb-6 font-display text-5xl font-semibold tracking-tight text-text sm:text-6xl md:text-7xl lg:text-8xl opacity-0 animate-fade-in-up motion-reduce:opacity-100 motion-reduce:animate-none">
      <span class="bg-gradient-to-br from-text via-text to-text/70 bg-clip-text bg-[length:300%_100%] bg-[position:0_0] animate-gradient-text">{name}</span>
    </h1>

    <!-- Role -->
    <p class="mb-4 text-lg font-medium text-text-secondary sm:text-xl opacity-0 animate-fade-in-up [animation-delay:0.15s] motion-reduce:opacity-100 motion-reduce:animate-none">
      {role}
    </p>

    <!-- Tagline -->
    <p class="max-w-md text-base leading-relaxed text-text-secondary sm:max-w-lg sm:text-lg opacity-0 animate-fade-in-up [animation-delay:0.3s] motion-reduce:opacity-100 motion-reduce:animate-none">
      {tagline}
    </p>

    <!-- CTAs -->
    <div class="mt-10 flex gap-4 opacity-0 animate-fade-in-up [animation-delay:0.45s] motion-reduce:opacity-100 motion-reduce:animate-none">
      <a
        href="/projects"
        class="group inline-flex items-center gap-2 rounded-md bg-primary px-6 py-3 text-base font-medium text-text-inverse shadow-sm transition-all hover:bg-primary-hover hover:shadow-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2"
      >
        View Projects
        <span class="transition-transform group-hover:-translate-x-0.5">→</span>
      </a>
      <a
        href="/blog"
        class="group inline-flex items-center gap-2 rounded-md border border-border bg-transparent px-6 py-3 text-base font-medium text-text shadow-sm transition-all hover:border-primary/40 hover:bg-surface-2 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2"
      >
        Read Blog
        <span class="transition-transform group-hover:-translate-x-0.5">→</span>
      </a>
    </div>
  </div>
</section>

