---
interface Props {
  name?: string;
  role?: string;
  tagline?: string;
}

const {
  name = 'Wael',
  role = 'Software Engineer',
  tagline = 'I build things for the web and write about the process.',
} = Astro.props;
---

<section class="relative mx-auto w-full px-4 sm:px-6 lg:px-8">
  <!-- Background decorative elements -->
  <div class="pointer-events-none absolute inset-0 overflow-hidden">
    <div class="hero-orb hero-orb-primary absolute -left-[10rem] top-1/4 h-96 w-96 rounded-full bg-gradient-to-br from-primary/20 to-transparent blur-3xl" />
    <div class="hero-orb hero-orb-secondary absolute -right-[10rem] top-1/3 h-80 w-80 rounded-full bg-gradient-to-bl from-primary/15 via-primary/5 to-transparent blur-3xl" />
  </div>

  <div class="relative mx-auto flex min-h-[70vh] max-w-screen-xl flex-col items-center justify-center py-24 text-center">
    <!-- Decorative line -->
    <div class="hero-line mb-8 h-px w-16 bg-gradient-to-b from-primary/60 to-transparent sm:mb-10" />

    <!-- Name -->
    <h1 class="hero-name mb-6 font-display text-5xl font-semibold tracking-tight text-text sm:text-6xl md:text-7xl lg:text-8xl">
      <span class="bg-gradient-to-br from-text via-text to-text/70 bg-clip-text bg-[length:300%_100%] bg-[position:0_0] [animation:gradientText_8s_ease-in-out_infinite]">{name}</span>
    </h1>

    <!-- Role -->
    <p class="hero-role mb-4 text-lg font-medium text-text-secondary sm:text-xl">
      {role}
    </p>

    <!-- Tagline -->
    <p class="hero-tagline max-w-md text-base leading-relaxed text-text-secondary sm:max-w-lg sm:text-lg">
      {tagline}
    </p>

    <!-- CTAs -->
    <div class="hero-ctas mt-10 flex gap-4">
      <a
        href="/projects"
        class="group inline-flex items-center gap-2 rounded-md bg-primary px-6 py-3 text-base font-medium text-text-inverse shadow-sm transition-all hover:bg-primary-hover hover:shadow-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2"
      >
        View Projects
        <span class="transition-transform group-hover:-translate-x-0.5">→</span>
      </a>
      <a
        href="/blog"
        class="group inline-flex items-center gap-2 rounded-md border border-border bg-transparent px-6 py-3 text-base font-medium text-text shadow-sm transition-all hover:border-primary/40 hover:bg-surface-2 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2"
      >
        Read Blog
        <span class="transition-transform group-hover:-translate-x-0.5">→</span>
      </a>
    </div>
  </div>
</section>

<style is:global>
  /* Staggered fade-in animation */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-name {
    animation: fadeInUp 0.6s ease-out forwards;
  }

  .hero-role {
    animation: fadeInUp 0.6s ease-out 0.15s forwards;
    opacity: 0;
  }

  .hero-tagline {
    animation: fadeInUp 0.6s ease-out 0.3s forwards;
    opacity: 0;
  }

  .hero-ctas {
    animation: fadeInUp 0.6s ease-out 0.45s forwards;
    opacity: 0;
  }

  /* Gradient orbs */
  .hero-orb {
    z-index: -1;
    will-change: transform;
    animation: orbFloat 20s ease-in-out infinite alternate;
  }

  .hero-orb-primary {
    animation-delay: 0s;
  }

  .hero-orb-secondary {
    animation-delay: -10s;
    animation-duration: 25s;
  }

  @keyframes orbFloat {
    0% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(15px, -10px) scale(1.05); }
    66% { transform: translate(-10px, 8px) scale(0.95); }
    100% { transform: translate(5px, -5px) scale(1.02); }
  }

  /* Animated gradient text */
  @keyframes gradientText {
    0%, 100% { background-position: 0% 0%; }
    50% { background-position: 100% 0%; }
  }

  /* Decorative line */
  .hero-line {
    animation: fadeInUp 0.6s ease-out forwards;
    opacity: 0;
    animation-delay: 0.1s;
  }
</style>
