---
import PostList from './PostList.astro';
import Pagination from '../ui/Pagination.astro';
import TagAside from '../layout/TagAside.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  posts: CollectionEntry<'blog'>[];
  tags?: Array<{ name: string; count: number }>;
  currentPage: number;
  totalPages: number;
}

const { posts, tags, currentPage, totalPages }: Props = Astro.props;
---

<div class="mx-auto w-full max-w-screen-xl px-4 sm:px-6 lg:px-8 py-12 lg:py-20">
  <h1 class="font-display text-4xl font-semibold tracking-tight text-text sm:text-5xl mb-2">
    Blog
  </h1>
  <p class="text-text-secondary mb-10">
    Thoughts on web development, TypeScript, and building for performance.
  </p>

  <div class="grid grid-cols-1 gap-x-8 lg:grid-cols-[1fr_20rem]">
    <div class="min-w-0">
      <PostList posts={posts} />
      <Pagination currentPage={currentPage ?? 1} totalPages={totalPages ?? 1} baseUrl="/blog/{page}" />
    </div>

    {tags && (
      <TagAside tags={tags} basePath="/blog" />
    )}
  </div>
</div>
