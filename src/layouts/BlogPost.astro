---
import Base from './Base.astro';

interface Props {
  title: string;
  description?: string;
  headings?: Array<{ depth: number; text: string; id: string }>;
}

const { title, description, headings } = Astro.props;
---

<Base title={title} description={description}>
  <main id="main-content" class="relative">
    <div class="mx-auto w-full max-w-screen-xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-x-8 lg:grid-cols-[1fr_256px] xl:grid-cols-[1fr_256px]">
        <!-- Article column -->
        <article>
          <slot />
        </article>

        <!-- TOC sidebar — visible at xl breakpoint -->
        {headings && headings.length > 0 && (
          <aside class="hidden lg:block" aria-label="Table of contents">
            <nav class="sticky top-24 max-h-[calc(100vh-8rem)] overflow-y-auto py-8">
              <h3 class="mb-4 text-sm font-semibold text-text-secondary uppercase tracking-wide">
                Contents
              </h3>
              <ul class="space-y-1 border-l border-border pl-4">
                {headings.map((heading) => (
                  <li class={`text-text-secondary transition-colors hover:text-text ${heading.depth === 2 ? 'border-l-2' : ''}`}>
                    <a
                      href={`#${heading.id}`}
                      class="block py-1 text-sm leading-relaxed"
                    >
                      {heading.text}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          </aside>
        )}
      </div>
    </div>
  </main>
</Base>
