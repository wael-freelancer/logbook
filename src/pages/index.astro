---
import BaseLayout from '@/layouts/Base.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
---

<BaseLayout title="Log Book" description="A personal portfolio and technical blog by a software engineer.">
  <Header />

  <main id="main-content" class="relative">
    <div class="mx-auto w-full max-w-screen-xl px-4 sm:px-6 lg:px-8">
      <!-- Placeholder content — to be replaced in Phase 4 -->
      <section class="flex min-h-[60vh] flex-col items-center justify-center py-24 text-center">
        <h1 class="mb-4 font-display text-5xl font-semibold tracking-tight text-text sm:text-6xl">
          Welcome to Log Book
        </h1>
        <p class="max-w-xl text-base leading-relaxed text-text-secondary sm:text-lg">
          A personal portfolio and technical blog. More content coming soon.
        </p>
      </section>
    </div>
  </main>

  <Footer />
</BaseLayout>
