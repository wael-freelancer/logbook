---
import BaseLayout from '@/layouts/Base.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import ProjectCard from '@/components/projects/ProjectCard.astro';
import TagAside from '@/components/layout/TagAside.astro';
import { getSortedProjects, getProjectTags, getFeaturedAndOtherProjects } from '@/lib/projects';

const sorted = await getSortedProjects();
const tags = await getProjectTags();
const { featured, other } = await getFeaturedAndOtherProjects();
---

<BaseLayout title="Projects — Log Book" description="Showcase of projects including portfolio sites, CLI tools, dashboards, and design systems.">
  <Header />
  <main id="main-content">
    <div class="mx-auto w-full max-w-screen-xl px-4 sm:px-6 lg:px-8 py-12 lg:py-20">
      <h1 class="font-display text-4xl font-semibold tracking-tight text-text sm:text-5xl mb-2">
        Projects
      </h1>
      <p class="text-text-secondary mb-10">
        Selected work spanning web applications, tooling, and design systems.
      </p>

      <div class="grid grid-cols-1 gap-x-8 lg:grid-cols-[1fr_20rem]">
        <div class="min-w-0">
          <!-- Featured projects -->
          {featured.length > 0 && (
            <section class="mb-16">
              <h2 class="mb-6 font-display text-xl font-semibold tracking-tight text-text-secondary uppercase">
                Featured
              </h2>
              <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
                {featured.map((project) => (
                  <ProjectCard project={project} featured />
                ))}
              </div>
            </section>
          )}

          <!-- All projects -->
          <section>
            <h2 class="mb-6 font-display text-xl font-semibold tracking-tight text-text-secondary uppercase">
              Other Projects
            </h2>
            <div class="grid gap-6 sm:grid-cols-2 xl:grid-cols-3">
              {other.map((project) => (
                <ProjectCard project={project} />
              ))}
            </div>
          </section>
        </div>

        <TagAside tags={tags} basePath="/projects" />
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
