---
import BaseLayout from '@/layouts/Base.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import BlogLayout from '@/components/blog/BlogLayout.astro';
import { getSortedPosts, getPostTags } from '@/lib/posts';

const sorted = await getSortedPosts();
const pageSize = 10;
const totalPages = Math.max(1, Math.ceil(sorted.length / pageSize));
const currentPage = 1;
const posts = sorted.slice(0, pageSize);

const tags = await getPostTags();
---

<BaseLayout title="Blog — Log Book" description="Technical articles about web development, TypeScript, Astro, and software engineering.">
  <Header />
  <main id="main-content">
    <BlogLayout posts={posts} tags={tags} currentPage={currentPage} totalPages={totalPages} />
  </main>
  <Footer />
</BaseLayout>
